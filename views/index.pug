extends layout

block content
  h1= title
  p Page updated successfully. Welcome to #{title}.
  button Sample Button
  button(type="button", class="btn btn-secondary", onclick="reduce()") Press me
  div#use take some away

script.
  let current = 11;
  let quantity = 2;

  function reduce() {
    current = current - quantity;

    if (current < 0) {
      current = 0;
    }

    document.getElementById("use").innerHTML =
      "Reduced by " + quantity + " to " + current;
  }
